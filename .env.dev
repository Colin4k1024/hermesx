# .env.dev - Local development template
# Copy to .env: cp .env.dev .env
# Replace every CHANGE_ME value before starting shared or exposed services.
# Then run: docker compose -f docker-compose.dev.yml up -d --build

# ─── LLM Provider ────────────────────────────────────────────────────────────
# Ollama (local, no API key needed)
LLM_API_URL=http://host.docker.internal:11434
LLM_API_KEY=ollama
LLM_MODEL=llama3.2

# Application model config
HERMES_MODEL=llama3.2
HERMES_PROVIDER=openai
HERMES_BASE_URL=
HERMES_API_KEY_LLM=
HERMES_API_MODE=openai

# ─── Admin Bootstrap ─────────────────────────────────────────────────────────
HERMES_ACP_TOKEN=CHANGE_ME_LOCAL_DEV_ACP_TOKEN_32_CHARS_MIN
HERMES_API_KEY=CHANGE_ME_LOCAL_DEV_API_KEY_32_CHARS_MIN

# ─── Infrastructure ──────────────────────────────────────────────────────────
POSTGRES_USER=hermes
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_DB=hermes

MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY
MINIO_BUCKET=hermes-skills

# ─── CORS ────────────────────────────────────────────────────────────────────
SAAS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# ─── Debug ───────────────────────────────────────────────────────────────────
HERMES_DEBUG=false

# ─── Grafana ─────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
