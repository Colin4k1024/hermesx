# .env.dev — Local development defaults
# Copy to .env: cp .env.dev .env
# Then run: docker compose -f docker-compose.dev.yml up -d --build

# ─── LLM Provider ────────────────────────────────────────────────────────────
# Ollama (local, no API key needed)
LLM_API_URL=http://host.docker.internal:11434
LLM_API_KEY=ollama
LLM_MODEL=llama3.2

# Application model config
HERMES_MODEL=llama3.2
HERMES_PROVIDER=openai
HERMES_BASE_URL=
HERMES_API_KEY_LLM=
HERMES_API_MODE=openai

# ─── Admin Bootstrap ─────────────────────────────────────────────────────────
HERMES_ACP_TOKEN=local-dev-acp-token-32chars-minimum!!
HERMES_API_KEY=local-dev-api-key-32chars-minimum!!

# ─── Infrastructure ──────────────────────────────────────────────────────────
POSTGRES_USER=hermes
POSTGRES_PASSWORD=hermes_local_dev
POSTGRES_DB=hermes

MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=hermes-skills

# ─── CORS ────────────────────────────────────────────────────────────────────
SAAS_ALLOWED_ORIGINS=*

# ─── Debug ───────────────────────────────────────────────────────────────────
HERMES_DEBUG=false

# ─── Grafana ─────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=hermesx
