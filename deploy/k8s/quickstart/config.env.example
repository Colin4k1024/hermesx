# Copy to config.env and fill in your values before running kubectl apply -k .
#
# Quickstart flat K8s deployment — config.env drives the hermes-llm-config Secret
# consumed by the bootstrap Job. All values here are injected as environment variables.
#
# ─── LLM Provider ─────────────────────────────────────────────────────────────
# REQUIRED. LLM base URL — MUST include /v1 suffix
# (go-openai v1.36.1 appends /chat/completions automatically)
LLM_API_URL=https://api.minimaxi.com/v1
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=MiniMax-M2.7-highspeed

# ─── Bootstrap / Admin ────────────────────────────────────────────────────────
# REQUIRED. Static bearer token for ACP admin endpoints (min 16 chars recommended).
# Must match the HERMES_ACP_TOKEN set in your hermes-agent Deployment.
HERMES_ACP_TOKEN=dev-bootstrap-token

# ─── PostgreSQL (optional — only if using an external database) ───────────────
# Leave commented to use the in-cluster StatefulSet (deploy/kind/postgres.yaml).
# Uncomment and set to use an external PostgreSQL instance.
# DATABASE_URL=postgres://hermes:your-password@pg.example.com:5432/hermes?sslmode=require

# ─── Redis (optional — only if using an external Redis) ─────────────────────
# Leave commented to run without Redis. Uncomment to enable Redis session/caching.
# REDIS_URL=redis://redis.example.com:6379/0
# REDIS_PASSWORD=

# ─── MinIO / Object Storage (optional — only if using external S3-compatible) ─
# Defaults to the in-cluster MinIO StatefulSet (deploy/kind/minio.yaml).
# Override only when using an external S3-compatible object store.
# MINIO_ENDPOINT=s3.amazonaws.com
# MINIO_ACCESS_KEY=your-access-key
# MINIO_SECRET_KEY=your-secret-key
# MINIO_BUCKET=hermes-skills
# MINIO_USE_SSL=true
