# ─── Hermes Agent — Production Configuration ────────────────────────────────
# Copy this file to .env and replace ALL CHANGEME values before starting.
# Generate secrets: openssl rand -hex 32
#
# WARNING: Services will REFUSE to start if required variables are missing.
# Never use default/weak passwords in production.

# ─── LLM Provider (required) ─────────────────────────────────────────────────
# The base URL WITHOUT /v1 — the server appends /v1/chat/completions internally.

# MiniMax (default — change model as needed)
LLM_API_URL=https://api.minimaxi.com
LLM_API_KEY=CHANGEME_LLM_API_KEY
LLM_MODEL=MiniMax-M2.7-highspeed

# ── Alternatives: uncomment one block below and comment out the MiniMax block ──

# OpenAI
# LLM_API_URL=https://api.openai.com
# LLM_API_KEY=CHANGEME_OPENAI_KEY
# LLM_MODEL=gpt-4o-mini

# Anthropic (via OpenAI-compat proxy)
# LLM_API_URL=https://api.anthropic.com
# LLM_API_KEY=CHANGEME_ANTHROPIC_KEY
# LLM_MODEL=claude-haiku-4-5-20251001

# Ollama (local — no key required for dev)
# LLM_API_URL=http://host.docker.internal:11434
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.2

# ─── Admin Bootstrap Token (minimum 32 characters) ──────────────────────────
# Used by bootstrap.sh to create tenants and API keys.
HERMES_ACP_TOKEN=CHANGEME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# IP-level attempts per minute for POST /admin/v1/bootstrap.
HERMES_BOOTSTRAP_RATE_LIMIT_RPM=5

# ─── Application API Key (minimum 32 characters) ────────────────────────────
HERMES_API_KEY=CHANGEME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# ─── Infrastructure Credentials ─────────────────────────────────────────────
POSTGRES_USER=hermes
POSTGRES_PASSWORD=CHANGEME_STRONG_PG_PASSWORD
POSTGRES_DB=hermes

MINIO_ACCESS_KEY=CHANGEME_MINIO_ACCESS
MINIO_SECRET_KEY=CHANGEME_MINIO_SECRET

REDIS_PASSWORD=

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated origins. Use specific origins in production, never *.
# Add http://localhost:5173 for local webui dev (npm run dev).
SAAS_ALLOWED_ORIGINS=https://your-domain.com
# SAAS_ALLOWED_ORIGINS=https://your-domain.com,http://localhost:5173

# ─── Optional: OIDC SSO (v1.3.0+) ──────────────────────────────────────────
# Activates OIDC token validation when OIDC_ISSUER_URL is set.
# Tokens are validated against the IdP's JWKS endpoint (auto-rotation).
# OIDC_ISSUER_URL=https://your-idp.example.com/realms/hermes
# OIDC_CLIENT_ID=hermes-app
# OIDC_TENANT_CLAIM=tenant_id
# OIDC_ROLES_CLAIM=roles
# OIDC_ACR_CLAIM=acr
